<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manajemen Reservasi - Pemancingan Suharno 2</title>
    
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: { brand: { green: '#297c3f', yellow: '#f4e918', red: '#e90023' } },
                    fontFamily: { sans: ['"Plus Jakarta Sans"', 'sans-serif'] }
                }
            }
        }
    </script>

    <style>
        /* Sembunyikan elemen print saat di layar */
        #print-area { display: none; }
        
        /* Pengaturan khusus untuk Print */
        @media print {
            @page { size: A5 portrait; margin: 1cm; }
            body * { visibility: hidden; }
            #print-area { display: block; }
            #print-area, #print-area * { visibility: visible; }
            #print-area { position: absolute; left: 0; top: 0; width: 100%; }
        }
    </style>
</head>
<body class="bg-gray-100 text-gray-800" x-data="reservationApp()">

    <!-- Header -->
    <header class="bg-brand-green text-white shadow-md">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-white text-brand-green rounded font-bold flex items-center justify-center">S2</div>
                <h1 class="text-xl font-bold">Admin Reservasi</h1>
            </div>
            <div>
                <span x-text="currentMonthName + ' ' + currentYear" class="font-semibold text-lg"></span>
            </div>
        </div>
    </header>

    <!-- Main Content: Kalender -->
    <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="bg-white rounded-2xl shadow-lg p-6">
            <div class="flex justify-between items-center mb-6">
                <button @click="changeMonth(-1)" class="p-2 hover:bg-gray-100 rounded-full text-gray-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
                </button>
                <h2 class="text-2xl font-bold text-gray-800" x-text="currentMonthName + ' ' + currentYear"></h2>
                <button @click="changeMonth(1)" class="p-2 hover:bg-gray-100 rounded-full text-gray-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
                </button>
            </div>

            <!-- Header Hari -->
            <div class="grid grid-cols-7 gap-2 text-center font-bold text-gray-500 mb-2">
                <div>Min</div><div>Sen</div><div>Sel</div><div>Rab</div><div>Kam</div><div>Jum</div><div>Sab</div>
            </div>

            <!-- Grid Tanggal -->
            <div class="grid grid-cols-7 gap-2">
                <template x-for="blank in blankDays">
                    <div class="h-24 bg-gray-50 rounded-xl border border-gray-100"></div>
                </template>
                <template x-for="day in daysInMonth">
                    <div @click="openDay(day)" 
                         class="h-24 border border-gray-200 rounded-xl p-2 cursor-pointer hover:border-brand-green hover:shadow-md transition relative bg-white flex flex-col">
                        <span class="text-sm font-semibold text-gray-700" x-text="day"></span>
                        
                        <!-- Indikator ada reservasi -->
                        <div class="mt-auto flex gap-1 flex-wrap">
                            <template x-for="res in getReservations(day).slice(0, 3)">
                                <div class="w-full text-xs bg-brand-green/10 text-brand-green truncate px-1 rounded" x-text="res.time + ' ' + res.name"></div>
                            </template>
                            <template x-if="getReservations(day).length > 3">
                                <div class="w-full text-xs text-gray-500 text-center">+<span x-text="getReservations(day).length - 3"></span> lagi</div>
                            </template>
                        </div>
                    </div>
                </template>
            </div>
        </div>
    </main>

    <!-- ==================== MODAL AREA ==================== -->

    <!-- Modal 1: List Reservasi Harian -->
    <div x-show="modals.list" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm" style="display: none;">
        <div @click.away="modals.list = false" class="bg-white rounded-2xl w-full max-w-2xl max-h-[90vh] flex flex-col shadow-2xl">
            <div class="p-6 border-b flex justify-between items-center">
                <h3 class="text-xl font-bold">Reservasi: <span class="text-brand-green" x-text="selectedDateString"></span></h3>
                <button @click="modals.list = false" class="text-gray-400 hover:text-red-500"><svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></button>
            </div>
            
            <div class="p-6 overflow-y-auto flex-1">
                <button @click="openForm()" class="mb-4 w-full py-3 bg-brand-green text-white font-bold rounded-xl hover:bg-green-700 transition flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg> Tambah Reservasi Baru
                </button>

                <div class="space-y-4">
                    <template x-if="dayReservations.length === 0">
                        <p class="text-center text-gray-500 py-4">Belum ada reservasi pada tanggal ini.</p>
                    </template>
                    <template x-for="res in dayReservations" :key="res.id">
                        <div class="border rounded-xl p-4 flex justify-between items-center hover:shadow-md transition">
                            <div>
                                <div class="font-bold text-lg" x-text="res.name"></div>
                                <div class="text-sm text-gray-600 mt-1">
                                    <span class="inline-block bg-gray-100 px-2 py-1 rounded">No: <span x-text="res.id"></span></span>
                                    <span class="inline-block bg-brand-yellow/30 text-yellow-800 px-2 py-1 rounded ml-2">Jam: <span x-text="res.time"></span></span>
                                    <span class="inline-block bg-blue-100 text-blue-800 px-2 py-1 rounded ml-2">Kursi: <span x-text="res.seat"></span></span>
                                </div>
                                <div class="text-sm text-gray-500 mt-2" x-text="res.details"></div>
                            </div>
                            <div class="flex flex-col gap-2">
                                <button @click="printTicket(res)" class="px-3 py-1 bg-gray-800 text-white text-sm rounded hover:bg-gray-700">Print A5</button>
                                <button @click="openForm(res)" class="px-3 py-1 bg-blue-500 text-white text-sm rounded hover:bg-blue-600">Edit</button>
                                <button @click="deleteRes(res.id)" class="px-3 py-1 bg-brand-red text-white text-sm rounded hover:bg-red-700">Hapus</button>
                            </div>
                        </div>
                    </template>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal 2: Form Tambah/Edit -->
    <div x-show="modals.form" class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 backdrop-blur-sm" style="display: none;">
        <div @click.away="modals.form = false" class="bg-white rounded-2xl w-full max-w-md p-6 shadow-2xl">
            <h3 class="text-xl font-bold mb-4" x-text="formData.id ? 'Edit Reservasi' : 'Tambah Reservasi'"></h3>
            
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Nama Pemesan</label>
                    <input type="text" x-model="formData.name" class="w-full border p-2 rounded-lg focus:ring-brand-green focus:border-brand-green outline-none" placeholder="Nama Lengkap">
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Pilih Jam</label>
                        <div @click="modals.time = true" class="w-full border p-2 rounded-lg cursor-pointer bg-gray-50 text-center font-bold text-brand-green hover:bg-gray-100">
                            <span x-text="formData.time || 'Pilih Jam'"></span>
                        </div>
                    </div>
                    <div>
                        <label class="block text-sm font-semibold text-gray-700 mb-1">Pilih Tempat Duduk</label>
                        <div @click="openSeatPicker()" class="w-full border p-2 rounded-lg cursor-pointer bg-gray-50 text-center font-bold text-blue-600 hover:bg-gray-100" :class="!formData.time ? 'opacity-50 cursor-not-allowed' : ''">
                            <span x-text="formData.seat || 'Pilih Kursi'"></span>
                        </div>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-1">Detail Pesanan Menu</label>
                    <textarea x-model="formData.details" rows="3" class="w-full border p-2 rounded-lg focus:ring-brand-green focus:border-brand-green outline-none" placeholder="Contoh: 2 Gurami Bakar, 1 Es Teh..."></textarea>
                </div>
            </div>

            <div class="mt-6 flex justify-end gap-3">
                <button @click="modals.form = false" class="px-4 py-2 border rounded-lg hover:bg-gray-50">Batal</button>
                <button @click="saveReservation()" class="px-4 py-2 bg-brand-green text-white rounded-lg hover:bg-green-700 font-bold">Simpan</button>
            </div>
        </div>
    </div>

    <!-- Modal 3: Time Picker -->
    <div x-show="modals.time" class="fixed inset-0 z-[60] flex items-center justify-center bg-black/40" style="display: none;">
        <div @click.away="modals.time = false" class="bg-white rounded-2xl w-full max-w-sm p-6 shadow-2xl">
            <h3 class="text-lg font-bold mb-4 text-center">Pilih Jam Kedatangan</h3>
            <div class="grid grid-cols-2 gap-3">
                <template x-for="time in timeSlots">
                    <button @click="selectTime(time)" 
                            class="p-3 border-2 rounded-xl font-bold hover:bg-brand-green hover:text-white hover:border-brand-green transition"
                            :class="formData.time === time ? 'bg-brand-green text-white border-brand-green' : 'border-gray-200 text-gray-700'">
                        <span x-text="time"></span> WIB
                    </button>
                </template>
            </div>
        </div>
    </div>

    <!-- Modal 4: Seat Picker -->
    <div x-show="modals.seat" class="fixed inset-0 z-[60] flex items-center justify-center bg-black/40" style="display: none;">
        <div @click.away="modals.seat = false" class="bg-white rounded-2xl w-full max-w-sm p-6 shadow-2xl">
            <h3 class="text-lg font-bold mb-2 text-center">Pilih Tempat Duduk</h3>
            <p class="text-xs text-center text-gray-500 mb-4">Jam: <span x-text="formData.time" class="font-bold"></span></p>
            
            <div class="grid grid-cols-5 gap-2">
                <template x-for="seat in seatSlots">
                    <button @click="!isSeatBooked(seat) ? selectSeat(seat) : null" 
                            class="p-2 border-2 rounded-lg font-bold text-sm transition"
                            :class="{
                                'bg-blue-500 text-white border-blue-500': formData.seat === seat,
                                'bg-gray-200 text-gray-400 border-gray-200 cursor-not-allowed': isSeatBooked(seat),
                                'border-gray-300 text-gray-700 hover:border-blue-500 hover:text-blue-500': !isSeatBooked(seat) && formData.seat !== seat
                            }">
                        <span x-text="seat"></span>
                    </button>
                </template>
            </div>
        </div>
    </div>

    <!-- Elemen Tersembunyi untuk Print A5 -->
    <div id="print-area" class="bg-white text-black p-8 font-sans">
        <div class="border-4 border-gray-800 p-6 rounded-2xl">
            <div class="text-center border-b-2 border-dashed border-gray-300 pb-4 mb-4">
                <h1 class="text-2xl font-extrabold uppercase tracking-widest">Pemancingan Suharno 2</h1>
                <p class="text-sm">Tiket Bukti Reservasi Resmi</p>
            </div>
            
            <div class="space-y-4">
                <div class="flex justify-between border-b pb-2">
                    <span class="font-bold text-gray-600">No. Reservasi:</span>
                    <span class="font-bold text-lg" x-text="printData.id"></span>
                </div>
                <div class="flex justify-between border-b pb-2">
                    <span class="font-bold text-gray-600">Nama Pemesan:</span>
                    <span class="font-bold text-lg" x-text="printData.name"></span>
                </div>
                <div class="flex justify-between border-b pb-2">
                    <span class="font-bold text-gray-600">Tanggal:</span>
                    <span class="font-bold text-lg" x-text="printData.date"></span>
                </div>
                <div class="flex justify-between border-b pb-2">
                    <span class="font-bold text-gray-600">Waktu Kedatangan:</span>
                    <span class="font-bold text-lg" x-text="printData.time + ' WIB'"></span>
                </div>
                <div class="flex justify-between border-b pb-2">
                    <span class="font-bold text-gray-600">Tempat Duduk:</span>
                    <span class="font-bold text-2xl" x-text="printData.seat"></span>
                </div>
                <div>
                    <span class="font-bold text-gray-600 block mb-1">Detail Pesanan Menu:</span>
                    <div class="p-3 bg-gray-100 rounded border text-sm" x-text="printData.details"></div>
                </div>
            </div>

            <div class="mt-8 text-center text-xs text-gray-500">
                <p>*Harap bawa tiket ini (cetak/foto) saat kedatangan.</p>
                <p>*Keterlambatan di atas 1 jam tanpa konfirmasi, tempat duduk dapat dialihkan.</p>
            </div>
        </div>
    </div>

    <!-- Script Logic Aplikasi -->
    <script>
        document.addEventListener('alpine:init', () => {
            Alpine.data('reservationApp', () => ({
                // Data Konfigurasi
                monthNames:['Januari', 'Februari', 'Maret', 'April', 'Mei', 'Juni', 'Juli', 'Agustus', 'September', 'Oktober', 'November', 'Desember'],
                timeSlots:['07:00', '10:00', '13:00', '16:00', '19:00', '21:00'],
                seatSlots:['A1', 'A2', 'A3', 'A4', 'A5', 'B1', 'B2', 'B3', 'B4', 'B5'],
                
                // State Kalender
                currentDate: new Date(),
                currentMonth: new Date().getMonth(),
                currentYear: new Date().getFullYear(),
                selectedDate: null,
                
                // State Data
                reservations: JSON.parse(localStorage.getItem('suharno2_reservations')) || [],
                dayReservations:[],
                
                // State Modals
                modals: { list: false, form: false, time: false, seat: false },
                
                // State Form
                formData: { id: null, name: '', time: '', seat: '', details: '' },
                printData: {},

                // Inisialisasi Kalender
                get daysInMonth() {
                    return new Date(this.currentYear, this.currentMonth + 1, 0).getDate();
                },
                get blankDays() {
                    let blank = new Date(this.currentYear, this.currentMonth, 1).getDay();
                    return Array.from({ length: blank });
                },
                get currentMonthName() {
                    return this.monthNames[this.currentMonth];
                },
                get selectedDateString() {
                    if(!this.selectedDate) return '';
                    return `${this.selectedDate} ${this.currentMonthName} ${this.currentYear}`;
                },
                getFormattedDate(day) {
                    // Format seragam YYYY-MM-DD
                    return `${this.currentYear}-${String(this.currentMonth + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
                },

                // Ganti Bulan
                changeMonth(step) {
                    let newMonth = this.currentMonth + step;
                    if (newMonth < 0) { this.currentMonth = 11; this.currentYear--; }
                    else if (newMonth > 11) { this.currentMonth = 0; this.currentYear++; }
                    else { this.currentMonth = newMonth; }
                },

                // Baca Data per Tanggal
                getReservations(day) {
                    let dateStr = this.getFormattedDate(day);
                    return this.reservations.filter(r => r.date === dateStr);
                },

                // Aksi Buka Tanggal
                openDay(day) {
                    this.selectedDate = day;
                    this.dayReservations = this.getReservations(day);
                    this.modals.list = true;
                },

                // Buka Form (Tambah/Edit)
                openForm(res = null) {
                    if (res) {
                        this.formData = { ...res }; // Mode Edit
                    } else {
                        this.formData = { id: null, name: '', time: '', seat: '', details: '' }; // Mode Tambah
                    }
                    this.modals.form = true;
                },

                // Pemilihan Jam & Kursi
                selectTime(time) {
                    this.formData.time = time;
                    this.formData.seat = ''; // Reset kursi jika jam diubah
                    this.modals.time = false;
                    // Langsung buka modal kursi setelah pilih jam
                    setTimeout(() => { this.modals.seat = true; }, 300);
                },
                openSeatPicker() {
                    if(!this.formData.time) { alert('Silakan pilih Jam terlebih dahulu!'); return; }
                    this.modals.seat = true;
                },
                selectSeat(seat) {
                    this.formData.seat = seat;
                    this.modals.seat = false;
                },
                isSeatBooked(seat) {
                    // Cek apakah kursi sudah dibooking di tanggal dan jam yang sama (kecuali sedang diedit)
                    let dateStr = this.getFormattedDate(this.selectedDate);
                    return this.reservations.some(r => 
                        r.date === dateStr && 
                        r.time === this.formData.time && 
                        r.seat === seat && 
                        r.id !== this.formData.id
                    );
                },

                // Simpan Data
                saveReservation() {
                    if(!this.formData.name || !this.formData.time || !this.formData.seat) {
                        alert("Nama, Jam, dan Tempat Duduk wajib diisi!");
                        return;
                    }

                    let dateStr = this.getFormattedDate(this.selectedDate);
                    
                    if (this.formData.id) {
                        // Update
                        let index = this.reservations.findIndex(r => r.id === this.formData.id);
                        this.reservations[index] = { ...this.formData, date: dateStr };
                    } else {
                        // Create (Generate random ID ex: RSV-12345)
                        let newId = 'RSV-' + Math.floor(10000 + Math.random() * 90000);
                        this.reservations.push({ ...this.formData, id: newId, date: dateStr });
                    }

                    // Save ke LocalStorage
                    localStorage.setItem('suharno2_reservations', JSON.stringify(this.reservations));
                    
                    // Refresh tampilan list
                    this.dayReservations = this.getReservations(this.selectedDate);
                    this.modals.form = false;
                },

                // Hapus Data
                deleteRes(id) {
                    if(confirm("Yakin ingin menghapus reservasi ini?")) {
                        this.reservations = this.reservations.filter(r => r.id !== id);
                        localStorage.setItem('suharno2_reservations', JSON.stringify(this.reservations));
                        this.dayReservations = this.getReservations(this.selectedDate);
                    }
                },

                // Print Data
                printTicket(res) {
                    this.printData = res;
                    // Jeda sebentar agar Alpine merender data ke DOM sebelum print dipanggil
                    setTimeout(() => {
                        window.print();
                    }, 100);
                }
            }));
        });
    </script>
</body>
</html>
